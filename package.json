{
  "name": "examgpt",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check": "bun run typecheck && bun run lint && bun run test",
    "db:generate": "bun run --filter @examgpt/db generate",
    "db:migrate": "bun run --filter @examgpt/db migrate",
    "db:studio": "bun run --filter @examgpt/db studio"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "bun@1.3.4",
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
