# Database
DATABASE_URL=postgresql://examgpt:examgpt@localhost:5434/examgpt

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Public API URL (web + mobile clients)
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_API_URL=http://localhost:4000

# Clerk (Phase 1) — enable Google OAuth + Email+Password + Email verification code.
# Disable Phone number / SMS (Clerk SMS does not support Indian numbers).
# Dev test emails: *+clerk_test@example.com with OTP 424242
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
# Webhook endpoint: POST {API_URL}/webhooks/clerk

# AI providers
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENROUTER_API_KEY=
# Defaults in packages/ai registry (override as needed).
# OCR default is gemini-3.5-flash (gemini-2.5-flash is blocked for new API keys).
AI_MODEL_OCR=gemini-3.5-flash
AI_MODEL_VISION_EXTRACT=gemini-3.5-flash
AI_MODEL_EMBEDDING=
AI_MODEL_CHAT=
AI_MODEL_INTENT=
AI_MODEL_REPORT=
AI_MODEL_PAPERGEN=
AI_MODEL_WEBSEARCH=
AI_MODEL_TITLE=

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Ingest
INGEST_PAGE_QUOTA=2000

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# mem0 (optional — chat degrades silently if missing)
MEM0_API_KEY=

# OpenRouter (intent-agent, web-search, etc.)
OPENROUTER_API_KEY=
# Per-user daily AI spend cap (USD). Fail-open if log query errors.
AI_DAILY_BUDGET_USD=5
# Attempt timer grace (seconds) after endsAt
ATTEMPT_GRACE_SEC=5
# Paper syllabus match threshold (0-1)
PAPER_SYLLABUS_MATCH_THRESHOLD=0.35

# Cloudflare R2 (Object Read & Write token on the target bucket)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
# Force local disk storage under apps/server/.data/uploads (dev fallback)
# STORAGE_BACKEND=local
# LOCAL_UPLOAD_DIR=

# Expo push
EXPO_ACCESS_TOKEN=

# OCR/vision temporarily routed to OpenAI via env override (Gemini billing pending); revert by removing AI_MODEL_OCR / AI_MODEL_VISION_EXTRACT.
