{
  "expo": {
    "name": "ExamGPT",
    "slug": "examgpt",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "examgpt",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.examgpt.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563eb"
      },
      "package": "app.examgpt.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ExamGPT to access photos when you upload notes.",
          "cameraPermission": "Allow ExamGPT to use the camera when you scan notes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
