// ExamGPT Prisma schema — Phase 0–2 (see TASKS.md §5)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ExamType {
  NEET
  JEE
  OTHER
}

enum DocumentKind {
  SYLLABUS
  NOTES
  BOOK
  PAPER
}

enum SourceType {
  UPLOAD_PDF
  UPLOAD_IMAGE
  URL
}

enum IngestStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum MessageRole {
  USER
  ASSISTANT
}

model User {
  id         String       @id // Clerk userId
  email      String?      @unique
  phone      String?      @unique
  name       String?
  age        Int?
  onboarded  Boolean      @default(false)
  /// Cumulative pages counted toward INGEST_PAGE_QUOTA
  pagesUsed  Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  exam       ExamProfile?
  documents  Document[]
  pushTokens PushToken[]
  chats      Chat[]
  aiUsage    AiUsageLog[]
  tests      Test[]
  attempts   Attempt[]
}

model ExamProfile {
  id                 String       @id @default(cuid())
  userId             String       @unique
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type               ExamType
  customName         String?
  targetYear         Int?
  syllabusDocumentId String?
  syllabusStatus     IngestStatus @default(PENDING)
  syllabusTopics     Json?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model Document {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind           DocumentKind
  title          String
  sourceType     SourceType
  fileKey        String?
  sourceUrl      String?
  mimeType       String?
  sizeBytes      Int?
  pageCount      Int?
  ingestStatus   IngestStatus   @default(PENDING)
  /// 0–100 overall; pages processed also tracked on DocumentPage
  ingestProgress Int            @default(0)
  failureReason  String?
  contentHash    String?
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  pages          DocumentPage[]

  @@index([userId, kind])
  @@index([contentHash])
  @@index([userId, ingestStatus])
}

model DocumentPage {
  id             String       @id @default(cuid())
  documentId     String
  document       Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  pageNumber     Int
  ocrStatus      IngestStatus @default(PENDING)
  hasHandwriting Boolean      @default(false)
  hasImages      Boolean      @default(false)
  hasTables      Boolean      @default(false)
  classification String?
  markdown       String?
  failureReason  String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([documentId, pageNumber])
  @@index([documentId, ocrStatus])
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([userId])
}

model Chat {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String    @default("New chat")
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@index([userId, updatedAt])
}

model Message {
  id         String      @id @default(cuid())
  chatId     String
  chat       Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  /// Client-generated UUID — idempotent local-first sync
  clientId   String      @unique
  role       MessageRole
  content    String
  /// [{documentId, title, pageNumber, chunkId?, score?}]
  citations  Json?
  /// [{url, title}] when web fallback used — never mixed into notes-cited answers
  webSources Json?
  /// not_in_notes | clarifying | notes | web
  kind       String?
  createdAt  DateTime    @default(now())

  @@index([chatId, createdAt])
}

model AiUsageLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  task       String
  model      String
  tokensIn   Int      @default(0)
  tokensOut  Int      @default(0)
  costUsd    Float?
  latencyMs  Int?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([task, createdAt])
}

// ─── Phase 4 — CBT ───────────────────────────────────────────

enum TestSource {
  PYQ_UPLOAD
  AI_GENERATED
}

enum TestStatus {
  EXTRACTING
  GENERATING
  NEEDS_REVIEW
  READY
  FAILED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  ANALYZED
}

enum SubmitType {
  MANUAL
  AUTO_TIMEOUT
}

enum EventType {
  VISIT
  LEAVE
  SELECT
  CHANGE
  CLEAR
  MARK_REVIEW
  UNMARK_REVIEW
  SAVE_NEXT
  APP_BACKGROUND
  APP_FOREGROUND
}

enum PaletteState {
  NOT_VISITED
  NOT_ANSWERED
  ANSWERED
  MARKED
  ANSWERED_MARKED
}

model Test {
  id                 String     @id @default(cuid())
  userId             String
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  source             TestSource
  title              String
  paperDocumentId    String?
  paperYear          Int?
  config             Json?
  durationMin        Int        @default(180)
  totalMarks         Int        @default(0)
  /// { correct: 4, wrong: -1, unattempted: 0 }
  markingScheme      Json
  status             TestStatus @default(EXTRACTING)
  syllabusMatchScore Float?
  failureReason      String?
  deletedAt          DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  questions          Question[]
  attempts           Attempt[]

  @@index([userId, status])
  @@index([userId, createdAt])
}

model Question {
  id               String   @id @default(cuid())
  testId           String
  test             Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  index            Int
  section          String?
  text             String
  imageKeys        String[] @default([])
  /// [{key:"A", text, imageKey?}]
  options          Json
  correctKey       String?
  answerConfidence Float?
  topic            String?
  subtopic         String?
  /// User reported bad extraction — excluded from scoring
  flagged          Boolean  @default(false)
  explanationCache Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([testId, index])
  @@index([testId])
}

model Attempt {
  id          String        @id @default(cuid())
  testId      String
  test        Test          @relation(fields: [testId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      AttemptStatus @default(IN_PROGRESS)
  startedAt   DateTime
  endsAt      DateTime
  submittedAt DateTime?
  submitType  SubmitType?
  score       Float?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  events      AttemptEvent[]
  responses   Response[]

  @@index([userId, status])
  @@index([testId, userId])
  @@index([status, endsAt])
}

model AttemptEvent {
  id            BigInt   @id @default(autoincrement())
  attemptId     String
  attempt       Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionIndex Int
  type          EventType
  optionKey     String?
  clientTs      DateTime
  serverTs      DateTime @default(now())
  batchId       String

  @@index([attemptId, questionIndex])
  @@index([attemptId, batchId])
}

model Response {
  id            String       @id @default(cuid())
  attemptId     String
  attempt       Attempt      @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionIndex Int
  selectedKey   String?
  paletteState  PaletteState @default(NOT_VISITED)
  timeSpentSec  Int          @default(0)
  visitCount    Int          @default(0)
  optionChanges Int          @default(0)
  isCorrect     Boolean?
  marksAwarded  Float?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([attemptId, questionIndex])
}
